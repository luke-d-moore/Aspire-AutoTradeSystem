# Container image name for AutoTradeSystem
AUTOTRADESYSTEM_IMAGE=autotradesystem:latest

# Default container port for AutoTradeSystem
AUTOTRADESYSTEM_PORT=8080

# Container image name for PricingSystem
PRICINGSYSTEM_IMAGE=pricingsystem:latest

# Container image name for TradeActionSystem
TRADEACTIONSYSTEM_IMAGE=tradeactionsystem:latest

# Default container port for TradeActionSystem
TRADEACTIONSYSTEM_PORT=8081

PRICINGSYSTEM_GRPCAPI=https://PricingSystem:7001
PRICINGSYSTEM_RESTAPI=https://PricingSystem:7250
# Change this to 8080 to match your Kestrel__Endpoints__http__Url
PRICINGSYSTEM_HTTP=https://PricingSystem:8080

PricingSystemBaseURL=https://pricingsystem:7001

RabbitMQQueue=TradeActionQueue

RabbitMQExchange=TradeActionExchange

ConnectionHostName=rabbitmq

ConnectionStrings__my-rabbit=amqp://guest:guest@rabbitmq:5672

